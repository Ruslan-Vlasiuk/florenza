# =============================================================================
# Florenza — environment variables
# Copy to .env.local for development, /opt/florenza/.env for production VPS
# =============================================================================

# --- Server ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Florenza

# --- PostgreSQL ---
DATABASE_URI=postgres://florenza:florenza_dev@localhost:5432/florenza
POSTGRES_USER=florenza
POSTGRES_PASSWORD=florenza_dev
POSTGRES_DB=florenza

# --- Payload CMS ---
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace_with_openssl_rand_base64_32
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- AI: Anthropic Claude (Лія + AI-content) ---
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_SIMPLE=claude-haiku-4-5-20251001
CLAUDE_MODEL_COMPLEX=claude-opus-4-7

# --- AI: Google Gemini (фото) ---
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# --- AI: Whisper local ---
WHISPER_BIN=/usr/local/bin/whisper
WHISPER_MODEL=small
WHISPER_LANG=uk

# --- Telegram bot ---
# Created via @BotFather. Set webhook to https://florenza-irpin.com/api/webhook/telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=florenza_bot
TELEGRAM_WEBHOOK_SECRET=

# --- Viber bot ---
# Created via Viber Admin Panel
VIBER_BOT_TOKEN=
VIBER_BOT_NAME=Florenza
VIBER_BOT_AVATAR=https://florenza-irpin.com/og-default.png

# --- Payments: Monobank Acquiring ---
# https://api.monobank.ua/docs/acquiring.html
MONO_ACQUIRING_TOKEN=
MONO_WEBHOOK_PUBKEY_URL=https://api.monobank.ua/api/merchant/pubkey

# --- Payments: LiqPay (резервний) ---
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# --- ПРРО Checkbox.ua ---
# https://checkbox.ua
CHECKBOX_API_URL=https://api.checkbox.ua/api/v1
CHECKBOX_LOGIN=
CHECKBOX_PASSWORD=
CHECKBOX_LICENSE_KEY=
CHECKBOX_CASHIER_KEY=

# --- Telegram алерт-бот для Варвари (окремий бот тільки для нотифікацій) ---
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Backblaze B2 (бекапи, free tier 10 GB) ---
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=florenza-backups

# --- Аналітика (внутрішня) ---
# Сіль для хешування IP, ротується щомісяця через cron
ANALYTICS_IP_SALT=replace_with_random_string

# --- Google Search Console (опційно) ---
# Service account JSON у файлі /opt/florenza/secrets/gsc.json
GSC_SERVICE_ACCOUNT_PATH=/opt/florenza/secrets/gsc.json

# --- Demo mode flag ---
# Якщо true — seed скрипт створює демо-контент. Вимикається після наповнення реальним.
ENABLE_DEMO_SEED=true
