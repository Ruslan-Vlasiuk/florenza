# =============================================================================
# Florenza — environment variables
# Copy to .env.local for development, /opt/florenza/.env for production VPS.
# All values starting with CHANGEME must be replaced before deploy.
# =============================================================================

# --- Server ---
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://florenza-irpin.com
NEXT_PUBLIC_SITE_NAME=Florenza
NEXT_PUBLIC_APP_VERSION=0.1.0

# --- PostgreSQL ---
# In production with docker-compose, host is `postgres` (service name).
# In local dev, port 5433 (florenza-postgres compose maps 5433->5432).
POSTGRES_USER=florenza
POSTGRES_PASSWORD=CHANGEME_openssl_rand_base64_32
POSTGRES_DB=florenza
DATABASE_URI=postgres://florenza:CHANGEME_openssl_rand_base64_32@postgres:5432/florenza

# --- Payload CMS ---
PAYLOAD_SECRET=CHANGEME_openssl_rand_hex_32
PAYLOAD_PUBLIC_SERVER_URL=https://florenza-irpin.com
# Set to "true" on the FIRST production deploy so Payload pushes the schema
# directly into Postgres. After the first successful start, REMOVE this line
# (or set to false). See payload.config.ts for context.
# PAYLOAD_PUSH=true

# --- Initial admin user (idempotent seed via `pnpm seed:admin`) ---
# Created on first run only. Skipped if a user with this email already exists.
INITIAL_ADMIN_EMAIL=CHANGEME@florenza-irpin.com
INITIAL_ADMIN_PASSWORD=CHANGEME_openssl_rand_base64_24
INITIAL_ADMIN_NAME=Owner

# --- AI: Anthropic Claude (Лія + AI-content) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=CHANGEME
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_SIMPLE=claude-haiku-4-5-20251001
CLAUDE_MODEL_COMPLEX=claude-opus-4-7

# --- AI: Google Gemini (фото) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGEME
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# --- AI: Whisper local (на VPS, для voice у Telegram) ---
# Soft-launch: вимкнено в коді webhook (текстовий fallback). Зніми коментар
# і виставі шлях коли Whisper буде встановлений на VPS / окремим сервісом.
WHISPER_BIN=/usr/local/bin/whisper-transcribe
WHISPER_MODEL=small
WHISPER_LANG=uk

# --- Telegram bot ---
# Created via @BotFather. Webhook auto-set via `pnpm tg:setup https://florenza-irpin.com`.
TELEGRAM_BOT_TOKEN=CHANGEME
TELEGRAM_BOT_USERNAME=FLORENZA_irpin_bot
TELEGRAM_WEBHOOK_SECRET=CHANGEME_openssl_rand_hex_32

# --- Telegram алерт-бот для Варвари (окремий бот тільки для notifications) ---
TELEGRAM_ADMIN_BOT_TOKEN=CHANGEME
TELEGRAM_ADMIN_CHAT_ID=CHANGEME

# --- Viber bot (вимкнено на soft-launch — додай credentials, перезапусти) ---
VIBER_BOT_TOKEN=
VIBER_BOT_NAME=Florenza
VIBER_BOT_AVATAR=https://florenza-irpin.com/og-default.png

# --- Payments: Monobank Acquiring ---
# Soft-launch: public sandbox token. Production token after merchant approval.
# https://api.monobank.ua/docs/acquiring.html
MONO_ACQUIRING_TOKEN=CHANGEME_sandbox_or_production
MONO_WEBHOOK_PUBKEY_URL=https://api.monobank.ua/api/merchant/pubkey

# --- Payments: LiqPay (резервний, soft-launch вимкнений) ---
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# --- ПРРО Checkbox.ua (soft-launch вимкнений до отримання credentials) ---
CHECKBOX_API_URL=https://api.checkbox.ua/api/v1
CHECKBOX_LOGIN=
CHECKBOX_PASSWORD=
CHECKBOX_LICENSE_KEY=
CHECKBOX_CASHIER_KEY=

# --- Backblaze B2 (бекапи, free tier 10 GB) ---
# Soft-launch може лишитись порожнім — backup.sh зберігає локально в /var/backups/florenza.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=florenza-backups

# --- Аналітика (внутрішня, server-side hashed IP) ---
# Сіль для хешування IP, ротується щомісяця через cron
ANALYTICS_IP_SALT=CHANGEME_openssl_rand_hex_32

# --- Cron / scheduled jobs ---
# Захищає /api/cron/* від виклику ззовні. Cron сервіс відправляє в заголовку.
CRON_SECRET=CHANGEME_openssl_rand_hex_32

# --- Google Search Console (опційно, після запуску) ---
# Service account JSON у файлі /opt/florenza/secrets/gsc.json
GSC_SERVICE_ACCOUNT_PATH=/opt/florenza/secrets/gsc.json

# --- Demo seed flag ---
# true → перший запуск засіває 42 demo букети, 30 тем блогу, 5 весіль etc.
# Вимикай після того як Варвара наповнить реальним.
ENABLE_DEMO_SEED=true
